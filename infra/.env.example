# ─────────────────────────────────────────────────────────────
# Environment variables for docker-compose (copy to .env)
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_platform
POSTGRES_PORT=5432

# LLM / Embedding Providers
LLM_PROVIDER=nvidia-nim
EMBEDDING_PROVIDER=sentence-transformers
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# NVIDIA NIM (OpenAI-compatible hosted API — default model: minimaxai/minimax-m3)
# NOTE: MiniMax M3 requires max_tokens or it returns an empty response (no choices).
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_MAX_TOKENS=2048

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# In-cluster URL for server-side proxying (Next.js rewrites → backend)
BACKEND_INTERNAL_URL=http://backend:8000

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Logging
LOG_LEVEL=INFO
